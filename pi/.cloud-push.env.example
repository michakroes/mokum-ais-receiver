# Copy to /home/pi/matsutec/.cloud-push.env and fill in.
# AIS_PUSH_KEY must be EXACTLY equal to the env var AIS_PUSH_KEY in Netlify.
CLOUD_INGEST_URL=https://YOUR-SITE.netlify.app/api/ingest
AIS_PUSH_KEY=replace-with-a-long-random-secret
LOCAL_STATE_URL=http://127.0.0.1:8801/state
# PUSH_INTERVAL: interval between pushes. Lower = fresher cloud, but more Netlify
# function invocations (4s ~= 650k/month, 6s ~= 430k/month). 6 stays comfortably "live"
# (frontend shows <20s = live).
PUSH_INTERVAL=6
