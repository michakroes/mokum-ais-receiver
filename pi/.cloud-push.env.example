# Kopieer naar /home/pi/matsutec/.cloud-push.env en vul in.
# AIS_PUSH_KEY moet EXACT gelijk zijn aan de env-var AIS_PUSH_KEY in Netlify.
CLOUD_INGEST_URL=https://JOUW-SITE.netlify.app/api/ingest
AIS_PUSH_KEY=vervang-door-een-lang-willekeurig-geheim
LOCAL_STATE_URL=http://127.0.0.1:8801/state
# PUSH_INTERVAL: interval tussen pushes. Lager = versere cloud, maar meer Netlify
# function-invocations (4s ~= 650k/maand, 6s ~= 430k/maand). 6 blijft ruim "live"
# (frontend toont <20s = live).
PUSH_INTERVAL=6
